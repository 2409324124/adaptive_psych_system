# Optional LLM integration. Leave empty to use the built-in fallback text.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# Host port for docker-compose publishing. Use 8001 for staging validation,
# then switch to 8000 for the final cutover.
PORT=8000

# Optional prebuilt image tag. Leave as default for local builds, or set this
# when deploying a loaded image archive with `docker compose up --no-build`.
IMAGE_NAME=cat-psych:cpu

# Session storage defaults used by docker-compose.yml.
CAT_PSYCH_SESSION_BACKEND=json
CAT_PSYCH_SESSION_DIR=/app/data/sessions
CAT_PSYCH_SESSION_TTL_SECONDS=7200
